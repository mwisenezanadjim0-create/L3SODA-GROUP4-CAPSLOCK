# ==========================================
# ENVIRONMENT VARIABLES - Dodos Car Limited
# ==========================================

# Server Configuration
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3000

# Admin Credentials (CHANGE THESE IN PRODUCTION!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-password-here

# Google Analytics (Optional)
# Get your tracking ID from https://analytics.google.com
GA_TRACKING_ID=G-XXXXXXXXXX

# Email Configuration (Optional - for email verification)
# Gmail Setup:
# 1. Enable 2FA on your Google account
# 2. Generate an App Password at: https://myaccount.google.com/apppasswords
# 3. Use the App Password below (not your regular Gmail password)
EMAIL_ENABLED=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=Dodos Car Limited <noreply@dodoscars.com>

# Alternative SMTP Providers:
# For Outlook: EMAIL_HOST=smtp-mail.outlook.com, EMAIL_PORT=587
# For SendGrid: EMAIL_HOST=smtp.sendgrid.net, EMAIL_PORT=587
# For Mailgun: EMAIL_HOST=smtp.mailgun.org, EMAIL_PORT=587

# Database (SQLite - automatically created)
# DB_PATH=./inventory.db (default, no need to set)

# Security Notes:
# - Change ADMIN_PASSWORD before deployment
# - Use strong, unique passwords
# - Enable EMAIL_ENABLED only with proper SMTP credentials
# - Keep GA_TRACKING_ID private